# CSE Predictor MCP Server Configuration

# Data refresh interval in minutes (default: 30)
CSE_REFRESH_INTERVAL=30

# Historical data retention in days (default: 365)
CSE_HISTORY_DAYS=365

# Prediction confidence threshold (default: 0.8 = 80%)
CSE_PREDICTION_THRESHOLD=0.8

# Enable verbose logging (default: false)
CSE_VERBOSE_LOGGING=false

# Data storage path (default: ./data)
CSE_DATA_PATH=./data

# External data sources (optional)
CSE_DATA_SOURCE_URL=

# Alpha Vantage API key (optional)
ALPHA_VANTAGE_API_KEY=

# News API key for sentiment analysis (optional)
NEWS_API_KEY=
