{
    "name":  "cse-predictor-mcp-server",
    "version":  "1.0.0",
    "description":  "MCP Server for Colombo Stock Exchange prediction with 80%+ accuracy target",
    "type":  "module",
    "main":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "bin":  {
                "cse-predictor":  "dist/index.js"
            },
    "scripts":  {
                    "build":  "echo \u0027Vercel build - API handled by @vercel/node runtime\u0027",
                    "start":  "node dist/index.js",
                    "dev":  "tsx src/index.ts",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "lint":  "eslint src/**/*.ts",
                    "clean":  "rimraf dist",
                    "inspect":  "npx @modelcontextprotocol/inspector node dist/index.js"
                },
    "keywords":  [
                     "mcp",
                     "model-context-protocol",
                     "colombo-stock-exchange",
                     "cse",
                     "stock-prediction",
                     "sri-lanka",
                     "financial-analysis"
                 ],
    "author":  "Work360",
    "license":  "MIT",
    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.0.0",
                         "@types/express":  "^5.0.6",
                         "cheerio":  "^1.0.0",
                         "csv-parse":  "^5.5.6",
                         "date-fns":  "^3.6.0",
                         "express":  "^5.2.1",
                         "node-fetch":  "^3.3.2",
                         "technicalindicators":  "^3.0.0",
                         "zod":  "^3.24.0"
                     },
    "devDependencies":  {
                            "@types/cors":  "^2.8.19",
                            "@types/node":  "^22.0.0",
                            "@typescript-eslint/eslint-plugin":  "^8.0.0",
                            "@typescript-eslint/parser":  "^8.0.0",
                            "@vercel/node":  "^5.7.7",
                            "eslint":  "^9.0.0",
                            "rimraf":  "^6.0.0",
                            "tsx":  "^4.19.0",
                            "typescript":  "^5.7.0",
                            "vitest":  "^2.1.0"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                },
    "directories":  {
                        "test":  "tests"
                    }
}
